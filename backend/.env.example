# Database (Docker - uses postgres service name)
DATABASE_URL=postgresql://cannabis_user:cannabis_password@postgres:5432/cannabis_aggregator

# Database (Local development - comment out Docker version above)
# DATABASE_URL=postgresql://user:password@localhost:5432/cannabis_aggregator

# Supabase (required for OAuth token verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# JWT — REQUIRED. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Server will refuse to start in production (DEBUG=false) without this set.
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration — set DEBUG=false in production
DEBUG=true
API_HOST=localhost
API_PORT=8000

# CORS — comma-separated list of allowed frontend origins.
# In production set this to your Vercel URL (and custom domain if you have one).
# Example: ALLOWED_ORIGINS=https://yourapp.vercel.app,https://utahcannabiscompare.com
# Omit or leave empty to use the localhost dev defaults.
ALLOWED_ORIGINS=

# Web Scraping
SCRAPER_TIMEOUT=30
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO

# Email Notifications (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here
NOTIFICATION_EMAIL_SENDER=alerts@utahbud.com
ALERT_CHECK_INTERVAL_HOURS=1
