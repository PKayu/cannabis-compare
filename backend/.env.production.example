# Production environment variables for Railway deployment
# Copy to .env on Railway via their dashboard (not committed to git)

# Database — Supabase PostgreSQL
# Use port 5432 (direct) or 6543 (transaction pooler) — Railway recommends direct for SQLAlchemy
# Found in: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:{password}@{project-ref}.supabase.co:5432/postgres

# Supabase Auth
SUPABASE_URL=https://{project-ref}.supabase.co
SUPABASE_SERVICE_KEY={service-role-key}

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY={generated-hex-64}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# CORS — set after Vercel URL is known (comma-separated)
# Example: https://utahcannabiscompare.vercel.app,https://utahcannabiscompare.com
ALLOWED_ORIGINS=https://your-vercel-url.vercel.app

# Scrapers
SCRAPER_TIMEOUT=30
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO

# Email (optional)
SENDGRID_API_KEY={sendgrid-key}
NOTIFICATION_EMAIL_SENDER=alerts@utahbud.com
ALERT_CHECK_INTERVAL_HOURS=1
